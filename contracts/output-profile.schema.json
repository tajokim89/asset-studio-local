{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asset-studio.local/contracts/output-profile.schema.json",
  "title": "Asset Studio Actor Output Profile",
  "description": "A provider-neutral export contract for directional pixel actor animation sheets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "family",
    "role",
    "frame",
    "directions",
    "actions",
    "import_hints"
  ],
  "properties": {
    "schema_version": { "const": "asset-studio.output-profile/v1" },
    "id": { "$ref": "#/$defs/identifier" },
    "title": { "type": "string", "minLength": 1, "maxLength": 256 },
    "family": { "const": "actor" },
    "role": { "enum": ["default", "example"] },
    "frame": { "$ref": "#/$defs/frame" },
    "directions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/direction" }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/action" }
    },
    "import_hints": { "$ref": "#/$defs/importHints" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "image_format", "transparent_background"],
      "properties": {
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "height": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "image_format": { "const": "png" },
        "transparent_background": { "const": true }
      }
    },
    "direction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "code"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3,
          "pattern": "^[A-Z]{1,3}$"
        }
      }
    },
    "pivot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "x", "y"],
      "properties": {
        "unit": { "const": "pixels" },
        "x": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "y": { "type": "integer", "minimum": 0, "maximum": 4095 }
      }
    },
    "sheetLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_name_template",
        "packing",
        "columns",
        "rows",
        "direction_order",
        "frame_order"
      ],
      "properties": {
        "file_name_template": {
          "type": "string",
          "minLength": 5,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9{}._-]*\\.png$"
        },
        "packing": { "const": "rows-by-direction" },
        "columns": { "type": "integer", "minimum": 1, "maximum": 64 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 16 },
        "direction_order": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "frame_order": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 0, "maximum": 63 }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "frame_count",
        "fps",
        "loop",
        "terminal",
        "beats",
        "prompt_contract",
        "acceptance",
        "pivot",
        "sheet_layout"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "frame_count": { "type": "integer", "minimum": 1, "maximum": 64 },
        "fps": { "type": "number", "exclusiveMinimum": 0, "maximum": 120 },
        "loop": { "type": "boolean" },
        "terminal": { "type": "boolean" },
        "beats": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "prompt_contract": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "acceptance": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "pivot": { "$ref": "#/$defs/pivot" },
        "sheet_layout": { "$ref": "#/$defs/sheetLayout" }
      }
    },
    "importHints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "texture_filter",
        "mipmaps",
        "alpha_mode",
        "coordinate_origin",
        "pixels_per_unit",
        "resource_path_template"
      ],
      "properties": {
        "engine": { "$ref": "#/$defs/identifier" },
        "texture_filter": { "const": "nearest" },
        "mipmaps": { "const": false },
        "alpha_mode": { "enum": ["straight", "premultiplied"] },
        "coordinate_origin": { "enum": ["top-left", "bottom-left"] },
        "pixels_per_unit": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "resource_path_template": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    }
  }
}
